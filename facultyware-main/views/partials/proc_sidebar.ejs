<% const sidebarUser = user || {}; const sidebarRoles = roles || sidebarUser.roles || []; %>
<aside id="proc-sidebar" class="proc-sidebar">
  <a href="/home" class="proc-brand">
    <div class="proc-brand-icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5 12 3l9 6.5"/><path d="M5 10v10h14V10"/><path d="M9 20v-6h6v6"/></svg>
    </div>
    <div>
      <div class="proc-brand-title">Facultyware</div>
      <div class="proc-brand-subtitle">Pengelola Aset</div>
    </div>
  </a>

  <nav aria-label="Menu Pengadaan Barang">
    <div class="proc-nav-title">Menu Pengadaan</div>
    <div class="proc-menu">
      <a class="proc-link" href="/home">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5 12 3l9 6.5"/><path d="M5 10v10h14V10"/><path d="M9 20v-6h6v6"/></svg>
        <span>Dashboard</span>
      </a>
      <a class="proc-link" href="/procurements/requests">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
        <span>Daftar Usulan Pengadaan</span>
      </a>
      <a class="proc-link" href="/procurements">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
        <span>Daftar Permohonan</span>
      </a>
      <a class="proc-link" href="/procurements/create">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/><path d="M4 4h16v16H4z"/></svg>
        <span>Buat Permohonan</span>
      </a>
      <a class="proc-link" href="/procurements/report">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 16V9"/><path d="M12 16V5"/><path d="M17 16v-3"/></svg>
        <span>Rekap Pengadaan</span>
      </a>
    </div>
  </nav>

  <div class="proc-sidebar-footer">
    <button class="theme-toggle" type="button" data-theme-toggle>
      <svg class="theme-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      <span data-theme-label>Mode Tampilan</span>
    </button>

    <div class="proc-user">
      <div class="proc-user-name"><%= sidebarUser.name || 'Pengguna' %></div>
      <div class="proc-user-email"><%= sidebarUser.email || '-' %></div>
      <div class="proc-user-role"><%= (sidebarRoles && sidebarRoles.length ? sidebarRoles.join(', ') : 'Role belum terbaca') %></div>
    </div>

    <a class="logout-link" href="/logout">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
      <span>Logout</span>
    </a>
  </div>
</aside>
