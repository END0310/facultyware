<%- include('../partials/header', { title, flash }) %>
<div class="fw-card">
  <h1 class="fw-title">Daftar Permohonan Pengadaan</h1>
  <p class="fw-subtitle">Alur: draft → submitted → approved/rejected → completed.</p>
  <div class="fw-form-actions" style="margin-top:0;">
    <a class="fw-btn primary" href="/procurements/create">Buat Permohonan</a>
    <a class="fw-btn" href="/procurements/items">Data Barang Pengadaan</a>
    <a class="fw-btn" href="/procurements/report">Buka Rekap</a>
  </div>
</div>
<div class="fw-card">
  <p class="fw-inline-note" style="margin-top:0;margin-bottom:14px;">Pantau status tiap permohonan dari draft hingga pencatatan aset untuk memastikan alur pengadaan berjalan rapi.</p>
  <table class="fw-table">
    <thead><tr><th>No Permohonan</th><th>Judul</th><th>Status</th><th>Item</th><th>Total Estimasi</th><th>Dibuat oleh</th><th>Tanggal</th><th>Aksi</th></tr></thead>
    <tbody>
      <% if (!procurements.length) { %><tr><td colspan="8">Belum ada permohonan.</td></tr><% } %>
      <% procurements.forEach(p => { %>
        <tr>
          <td><%= p.request_number %></td>
          <td><%= p.title %></td>
          <td><span class="fw-badge <%= p.status %>"><%= p.status %></span></td>
          <td><%= p.item_count %></td>
          <td>Rp <%= rupiah(p.total_estimated_price) %></td>
          <td><%= p.created_by_name || '-' %></td>
          <td><%= p.created_at || '-' %></td>
          <td><a class="fw-btn" href="/procurements/<%= p.id %>">Detail</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
