<%- include('../partials/header', { title: 'Daftar Permohonan Pengadaan', user: currentUser }) %>
<% const badgeClass = (status) => status === 'rejected' ? 'badge-destructive' : (status === 'approved' || status === 'completed' ? 'badge-primary' : 'badge-secondary'); %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold tracking-tight">Daftar Permohonan Pengadaan</h1>
    <p class="text-foreground mt-2">Alur: draft → submitted → approved/rejected → completed.</p>
  </div>
  <a href="/procurements/create" class="btn-primary">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M5 12h14"/>
    </svg>
    Buat Permohonan
  </a>
</div>

<div class="space-y-4 mb-6">
  <div class="flex gap-2 flex-wrap">
    <a href="/procurements/items" class="btn-sm-outline">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      Data Barang Pengadaan
    </a>
    <a href="/procurements/report" class="btn-sm-outline">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/>
      </svg>
      Buka Rekap
    </a>
  </div>
</div>

<!-- Search bar -->
<div class="mb-4">
  <form method="GET" action="/procurements" style="display:flex;gap:8px;align-items:center;">
    <input type="text" name="search" value="<%= search %>" placeholder="Cari nomor permohonan atau judul..." class="input" style="flex:1;max-width:360px;" />
    <button type="submit" class="btn-outline">Cari</button>
    <% if (search) { %>
    <a href="/procurements" class="btn-ghost text-sm">Reset</a>
    <% } %>
  </form>
</div>

<div class="card overflow-hidden">
  <% if (!procurements.length) { %>
    <div class="p-12 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
      </svg>
      <h3 class="text-sm font-medium text-center"><%= search ? 'Tidak ada hasil untuk "' + search + '"' : 'Belum ada permohonan' %></h3>
      <p class="text-sm text-foreground mt-1"><%= search ? 'Coba kata kunci lain.' : 'Mulai dengan membuat permohonan pengadaan baru' %></p>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>No Permohonan</th>
            <th>Judul</th>
            <th>Status</th>
            <th>Item</th>
            <th>Total Estimasi</th>
            <th>Dibuat oleh</th>
            <th>Tanggal</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% procurements.forEach(p => { %>
            <tr>
              <td><%= p.request_number %></td>
              <td><%= p.title %></td>
              <td>
                <span class="<%= badgeClass(p.status) %>"><%= p.status %></span>
              </td>
              <td><%= p.item_count %></td>
              <td>Rp <%= rupiah(p.total_estimated_price) %></td>
              <td><%= p.created_by_name || '-' %></td>
              <td><%= new Date(p.created_at).toLocaleDateString('id-ID') %></td>
              <td>
                <a href="/procurements/<%= p.id %>" class="btn-sm-outline">Detail</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-top:1px solid var(--color-border, #e5e7eb);font-size:14px;color:#6b7280;">
    <span>Menampilkan <strong><%= procurements.length %></strong> dari <strong><%= totalItems %></strong> permohonan</span>
    <% if (totalPages > 1) { %>
    <div style="display:flex;gap:8px;align-items:center;">
      <a href="/procurements?page=<%= Math.max(1, currentPage - 1) %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
         class="btn-sm-outline<%= currentPage <= 1 ? ' pointer-events-none opacity-50' : '' %>">← Prev</a>
      <span>Hal <strong><%= currentPage %></strong> / <%= totalPages %></span>
      <a href="/procurements?page=<%= Math.min(totalPages, currentPage + 1) %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
         class="btn-sm-outline<%= currentPage >= totalPages ? ' pointer-events-none opacity-50' : '' %>">Next →</a>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
