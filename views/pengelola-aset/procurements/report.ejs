<%- include('../partials/header', { title, flash }) %>
<%
  const currentFilters = typeof filters !== 'undefined' ? filters : {};
  const currentReportType = typeof reportType !== 'undefined'
    ? reportType
    : (currentFilters.report_type || 'procurements');
  const currentStatuses = Array.isArray(statuses) ? statuses : [];
  const currentRows = Array.isArray(rows) ? rows : [];
  const badgeClass = (status) => status === 'rejected' ? 'badge-destructive' : (status === 'approved' || status === 'completed' ? 'badge-primary' : 'badge-secondary');
%>

<section class="card p-6 mb-6">
  <h1 class="text-3xl font-bold tracking-tight">Rekap Pengadaan</h1>
  <p class="mt-2 text-foreground">Filter rekap usulan, permohonan, atau list asset lalu export CSV sesuai kebutuhan.</p>
</section>

<form class="card p-6 form mb-6" method="get" action="/procurements/report" data-report-filter-form>
  <div class="mb-6 border-b pb-4">
    <h2 class="text-lg font-semibold">Filter Rekap</h2>
    <p class="mt-1 text-sm text-foreground">Gunakan filter berikut untuk mempersempit data laporan sebelum export CSV.</p>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div class="field"><label>Jenis Rekap</label><select name="report_type" data-report-type-select><option value="requests" <%= currentReportType === 'requests' ? 'selected' : '' %>>Usulan</option><option value="procurements" <%= currentReportType === 'procurements' ? 'selected' : '' %>>Permohonan</option><option value="assets" <%= currentReportType === 'assets' ? 'selected' : '' %>>List Asset</option></select></div>
    <div class="field"><label>Status</label><select name="status" data-report-status-select><option value="">Semua</option><% currentStatuses.forEach(s => { %><option value="<%= s %>" <%= currentFilters.status === s ? 'selected' : '' %>><%= s %></option><% }) %></select></div>
    <div class="field"><label>Tanggal Awal</label><input type="date" name="start_date" value="<%= currentFilters.start_date || '' %>"></div>
    <div class="field"><label>Tanggal Akhir</label><input type="date" name="end_date" value="<%= currentFilters.end_date || '' %>"></div>
  </div>
  <div class="mt-6 flex gap-2 flex-wrap">
    <button class="btn-primary" type="submit">Filter</button>
    <a class="btn-outline" href="/procurements/report/print?report_type=<%= currentReportType %>&status=<%= currentFilters.status || '' %>&start_date=<%= currentFilters.start_date || '' %>&end_date=<%= currentFilters.end_date || '' %>" target="_blank" rel="noreferrer">Cetak</a>
    <a class="btn-outline" href="/procurements/report/export?report_type=<%= currentReportType %>&status=<%= currentFilters.status || '' %>&start_date=<%= currentFilters.start_date || '' %>&end_date=<%= currentFilters.end_date || '' %>">Export CSV</a>
  </div>
</form>

<section class="card p-6">
  <div class="overflow-x-auto">
    <% if (currentReportType === 'requests') { %>
      <table class="table">
        <thead><tr><th>No Usulan</th><th>Nama Barang</th><th>Spesifikasi</th><th>Jumlah</th><th>Status</th><th>Created</th><th>Updated</th><th>Pengusul</th></tr></thead>
        <tbody>
          <% if (!currentRows.length) { %><tr><td colspan="8">Data tidak ditemukan.</td></tr><% } %>
          <% currentRows.forEach(r => { %>
            <tr>
              <td><%= r.request_number %></td><td><%= r.name %></td><td><%= r.specification || '-' %></td><td><%= r.quantity %></td><td><span class="<%= badgeClass(r.status) %>"><%= r.status %></span></td><td><%= r.created_at || '-' %></td><td><%= r.updated_at || '-' %></td><td><%= r.employee_name || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else if (currentReportType === 'assets') { %>
      <table class="table">
        <thead><tr><th>Kode Asset</th><th>Nama Asset</th><th>Brand/Model</th><th>Serial Number</th><th>Spesifikasi</th><th>Tanggal Perolehan</th><th>Harga</th><th>Status</th></tr></thead>
        <tbody>
          <% if (!currentRows.length) { %><tr><td colspan="8">Data tidak ditemukan.</td></tr><% } %>
          <% currentRows.forEach(r => { %>
            <tr>
              <td><%= r.code %></td><td><%= r.name %></td><td><%= [r.brand, r.model].filter(Boolean).join(' / ') || '-' %></td><td><%= r.serial_number || '-' %></td><td><%= r.specification || '-' %></td><td><%= r.acquisition_date || '-' %></td><td>Rp <%= rupiah(r.acquisition_cost) %></td><td><span class="badge-outline"><%= r.status || '-' %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <table class="table">
        <thead><tr><th>No Permohonan</th><th>Judul</th><th>Barang</th><th>Jumlah</th><th>Estimasi</th><th>Status</th><th>Created</th><th>Updated</th><th>Created By</th></tr></thead>
        <tbody>
          <% if (!currentRows.length) { %><tr><td colspan="9">Data tidak ditemukan.</td></tr><% } %>
          <% currentRows.forEach(r => { %>
            <tr>
              <td><%= r.request_number %></td><td><%= r.title %></td><td><%= r.item_name || '-' %></td><td><%= r.quantity || '-' %></td><td>Rp <%= rupiah(r.estimated_price) %></td><td><span class="<%= badgeClass(r.status) %>"><%= r.status %></span></td><td><%= r.created_at || '-' %></td><td><%= r.updated_at || '-' %></td><td><%= r.created_by_name || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
