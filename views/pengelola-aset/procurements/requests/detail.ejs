<%- include('../../partials/header', { title, flash }) %>
<% const badgeClass = (status) => status === 'rejected' ? 'badge-destructive' : 'badge-secondary'; %>
<% const statusLabel = (status) => ({ submitted: 'Menunggu Pengelola Aset', rejected: 'Ditolak Pengelola Aset' }[status] || status); %>

<section class="card p-6 mb-6">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Detail Usulan: <%= request.request_number %></h1>
      <p class="mt-2 text-foreground">Tinjau usulan Ketua Departemen sebelum diteruskan ke Wakil Dekan.</p>
    </div>
    <span class="<%= badgeClass(request.status) %>"><%= statusLabel(request.status) %></span>
  </div>
</section>

<section class="grid gap-6 lg:grid-cols-2">
  <div class="card p-6">
    <h2 class="mb-4 text-lg font-semibold">Informasi Usulan</h2>
    <table class="table">
      <tbody>
        <tr><th>Judul</th><td><%= request.title %></td></tr>
        <tr><th>No Usulan</th><td><%= request.request_number %></td></tr>
        <tr><th>Pengusul</th><td><%= request.employee_name || '-' %></td></tr>
        <tr><th>Tanggal dibuat</th><td><%= request.created_at || '-' %></td></tr>
        <tr><th>Terakhir diperbarui</th><td><%= request.updated_at || '-' %></td></tr>
      </tbody>
    </table>
  </div>
  <div class="card p-6">
    <h2 class="mb-4 text-lg font-semibold">Aksi Pengelola Aset</h2>
    <% if (request.status === 'submitted' && request.request_number && request.request_number.startsWith('REQ-')) { %>
      <div class="flex gap-2 flex-wrap">
        <form action="/procurements/requests/<%= request.id %>/status" method="post">
          <input type="hidden" name="status" value="submitted">
          <button class="btn-primary" type="submit">Teruskan ke Wakil Dekan</button>
        </form>
        <form action="/procurements/requests/<%= request.id %>/status" method="post">
          <input type="hidden" name="status" value="rejected">
          <button class="btn-outline" type="submit">Tolak Usulan</button>
        </form>
      </div>
      <p class="mt-3 text-sm text-foreground">Usulan yang diteruskan akan masuk ke daftar permohonan Wakil Dekan.</p>
    <% } else { %>
      <p class="text-foreground">Usulan ini sudah diproses dengan status <strong><%= statusLabel(request.status) %></strong>.</p>
    <% } %>
  </div>
</section>

<section class="card p-6 mt-6">
  <h2 class="mb-4 text-lg font-semibold">Daftar Barang Usulan</h2>
  <div class="overflow-x-auto">
    <table class="table">
      <thead><tr><th>Nama Barang</th><th>Spesifikasi</th><th>Jumlah</th><th>Estimasi Harga</th><th>Subtotal</th></tr></thead>
      <tbody>
        <% if (!items.length) { %><tr><td colspan="5">Belum ada item pada usulan ini.</td></tr><% } %>
        <% items.forEach(item => { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.specification || '-' %></td>
            <td><%= item.quantity %></td>
            <td>Rp <%= rupiah(item.estimated_price) %></td>
            <td>Rp <%= rupiah((item.quantity || 0) * (item.estimated_price || 0)) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../../partials/footer') %>
