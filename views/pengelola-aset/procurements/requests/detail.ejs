<%- include('../../partials/header', { title, flash }) %>
<% const badgeClass = (status) => status === 'rejected' ? 'badge-destructive' : (status === 'approved' ? 'badge-primary' : 'badge-secondary'); %>

<section class="card p-6 mb-6">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Detail Usulan: <%= request.request_number %></h1>
      <p class="mt-2 text-foreground">Kelola status usulan sebelum menjadi permohonan pengadaan.</p>
    </div>
    <span class="<%= badgeClass(request.status) %>"><%= request.status %></span>
  </div>
</section>

<section class="grid gap-6 lg:grid-cols-2">
  <div class="card p-6">
    <h2 class="mb-4 text-lg font-semibold">Informasi Usulan</h2>
    <table class="table">
      <tbody>
        <tr><th>Nama Barang</th><td><%= request.name %></td></tr>
        <tr><th>Spesifikasi</th><td><%= request.specification || '-' %></td></tr>
        <tr><th>Jumlah</th><td><%= request.quantity %></td></tr>
        <tr><th>Pengusul</th><td><%= request.employee_name || '-' %></td></tr>
        <tr><th>Submitted</th><td><%= request.submitted_at || '-' %></td></tr>
        <tr><th>Disetujui oleh</th><td><%= request.approved_by_name || '-' %></td></tr>
        <tr><th>Approved at</th><td><%= request.approved_at || '-' %></td></tr>
      </tbody>
    </table>
  </div>
  <div class="card p-6">
    <h2 class="mb-4 text-lg font-semibold">Aksi Pengelola Aset</h2>
    <form class="form" action="/procurements/requests/<%= request.id %>/status" method="post">
      <div class="field">
        <label>Status Usulan</label>
        <select name="status" required>
          <% requestStatuses.forEach(s => { %><option value="<%= s %>" <%= request.status === s ? 'selected' : '' %>><%= s %></option><% }) %>
        </select>
        <small>Pilih status terbaru agar proses pengadaan berikutnya sesuai alur.</small>
      </div>
      <div class="mt-4 flex gap-2 flex-wrap">
        <button class="btn-primary" type="submit">Ubah Status</button>
        <a class="btn-outline" href="/procurements/create?request_id=<%= request.id %>">Buat Permohonan dari Usulan</a>
      </div>
    </form>
  </div>
</section>

<%- include('../../partials/footer') %>
