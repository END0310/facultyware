<%- include('../../partials/header', { title, flash }) %>
<% const badgeClass = (status) => status === 'rejected' ? 'badge-destructive' : (status === 'approved' ? 'badge-primary' : 'badge-secondary'); %>

<section class="card p-6 mb-6">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Daftar Usulan Pengadaan</h1>
      <p class="mt-2 text-foreground">Usulan dari Ketua Departemen yang diterima Pengelola Aset.</p>
    </div>
    <div class="flex gap-2 flex-wrap">
      <a class="btn-primary" href="/procurements/report?report_type=requests">Lihat Rekap Usulan</a>
      <a class="btn-outline" href="/procurements">Ke Permohonan</a>
    </div>
  </div>
</section>

<section class="card p-6">
  <p class="mb-4 text-foreground">Gunakan daftar ini untuk meninjau usulan masuk sebelum diubah statusnya atau diteruskan menjadi permohonan pengadaan.</p>
  <div class="overflow-x-auto">
    <table class="table">
      <thead><tr><th>No Usulan</th><th>Barang</th><th>Spesifikasi</th><th>Jumlah</th><th>Pengusul</th><th>Status</th><th>Tanggal</th><th>Aksi</th></tr></thead>
      <tbody>
        <% if (!requests.length) { %><tr><td colspan="8">Belum ada data usulan.</td></tr><% } %>
        <% requests.forEach(r => { %>
          <tr>
            <td><%= r.request_number %></td>
            <td><%= r.name %></td>
            <td><%= r.specification || '-' %></td>
            <td><%= r.quantity %></td>
            <td><%= r.employee_name || '-' %></td>
            <td><span class="<%= badgeClass(r.status) %>"><%= r.status %></span></td>
            <td><%= r.created_at || r.submitted_at || '-' %></td>
            <td><a class="btn-sm-outline" href="/procurements/requests/<%= r.id %>">Detail</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../../partials/footer') %>
