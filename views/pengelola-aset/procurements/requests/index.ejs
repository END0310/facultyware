<%- include('../../partials/header', { title, flash }) %>
<div class="fw-card">
  <h1 class="fw-title">Daftar Usulan Pengadaan</h1>
  <p class="fw-subtitle">Usulan dari Ketua Departemen yang diterima Pengelola Aset.</p>
  <div class="fw-form-actions" style="margin-top:0;">
    <a class="fw-btn primary" href="/procurements/report?report_type=requests">Lihat Rekap Usulan</a>
    <a class="fw-btn" href="/procurements">Ke Permohonan</a>
  </div>
</div>
<div class="fw-card">
  <p class="fw-inline-note" style="margin-top:0;margin-bottom:14px;">Gunakan daftar ini untuk meninjau usulan masuk sebelum diubah statusnya atau diteruskan menjadi permohonan pengadaan.</p>
  <table class="fw-table">
    <thead><tr><th>No Usulan</th><th>Barang</th><th>Spesifikasi</th><th>Jumlah</th><th>Pengusul</th><th>Status</th><th>Tanggal</th><th>Aksi</th></tr></thead>
    <tbody>
      <% if (!requests.length) { %><tr><td colspan="8">Belum ada data usulan.</td></tr><% } %>
      <% requests.forEach(r => { %>
        <tr>
          <td><%= r.request_number %></td>
          <td><%= r.name %></td>
          <td><%= r.specification || '-' %></td>
          <td><%= r.quantity %></td>
          <td><%= r.employee_name || '-' %></td>
          <td><span class="fw-badge <%= r.status %>"><%= r.status %></span></td>
          <td><%= r.created_at || r.submitted_at || '-' %></td>
          <td><a class="fw-btn" href="/procurements/requests/<%= r.id %>">Detail</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../../partials/footer') %>
