<!doctype html>
<html lang="id">
<head>
  <%- include('../../partials/theme_head') %>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || 'Facultyware' %></title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="stylesheet" href="/assets/styles.css">
  <%- include('styles') %>
</head>
<body>
<div class="proc-shell">
  <%- include('sidebar', { user: currentUser || null, roles: currentUser?.roles || [] }) %>
  <main class="proc-main">
    <% if (flash) { %>
      <div class="fw-flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>
