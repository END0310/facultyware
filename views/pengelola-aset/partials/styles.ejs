<style>
  body { margin: 0; background: #f3f6fb; color: hsl(var(--foreground)); font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
  .proc-shell { min-height: 100vh; display: grid; grid-template-columns: 300px 1fr; }
  .proc-sidebar { position: sticky; top: 0; height: 100vh; display: flex; flex-direction: column; gap: 18px; padding: 18px; border-right: 1px solid hsl(var(--border)); background: linear-gradient(180deg, hsl(var(--sidebar)) 0%, hsl(var(--card)) 100%); box-shadow: 8px 0 24px rgba(15, 23, 42, .06); }
  .proc-brand { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 16px; color: hsl(var(--sidebar-foreground)); text-decoration: none; background: hsl(var(--sidebar-accent)); border: 1px solid hsl(var(--sidebar-border)); }
  .proc-brand-icon { width: 42px; height: 42px; border-radius: 14px; display: grid; place-items: center; background: hsl(var(--sidebar-primary)); color: hsl(var(--sidebar-primary-foreground)); }
  .proc-brand-title { font-weight: 800; line-height: 1.2; }
  .proc-brand-subtitle { font-size: 12px; color: hsl(var(--muted-foreground)); }
  .proc-nav-title { margin: 8px 10px; font-size: 12px; text-transform: uppercase; letter-spacing: .07em; color: hsl(var(--muted-foreground)); font-weight: 800; }
  .proc-menu { display: grid; gap: 7px; }
  .proc-link { display: flex; align-items: center; gap: 11px; min-height: 42px; padding: 10px 12px; border-radius: 13px; text-decoration: none; color: hsl(var(--sidebar-foreground)); border: 1px solid transparent; transition: .16s ease; font-size: 14px; font-weight: 600; }
  .proc-link svg { width: 18px; height: 18px; flex: 0 0 18px; }
  .proc-link:hover, .proc-link[aria-current="page"] { background: hsl(var(--sidebar-accent)); color: hsl(var(--sidebar-accent-foreground)); border-color: hsl(var(--sidebar-border)); transform: translateX(2px); }
  .proc-sidebar-footer { margin-top: auto; display: grid; gap: 10px; }
  .proc-user { border: 1px solid hsl(var(--sidebar-border)); border-radius: 16px; padding: 13px; background: hsl(var(--background)); }
  .proc-user-name { font-weight: 800; font-size: 14px; }
  .proc-user-email, .proc-user-role { font-size: 12px; color: hsl(var(--muted-foreground)); word-break: break-word; margin-top: 2px; }
  .theme-toggle { width: 100%; border: 1px solid hsl(var(--border)); border-radius: 13px; padding: 10px 12px; background: hsl(var(--background)); color: hsl(var(--foreground)); display: flex; align-items: center; justify-content: center; gap: 9px; cursor: pointer; font-weight: 700; }
  .theme-toggle svg { width: 17px; height: 17px; }
  .logout-link { display: flex; align-items: center; justify-content: center; gap: 9px; border-radius: 13px; padding: 10px 12px; text-decoration: none; background: hsl(var(--destructive)); color: hsl(var(--destructive-foreground)); font-weight: 800; }
  .logout-link svg { width: 17px; height: 17px; }
  .proc-main { min-width: 0; padding: 28px; background: linear-gradient(180deg, #f7f9fc 0%, #eef3f9 100%); }
  .proc-hero { margin-bottom: 20px; border: 1px solid #d5deea; border-radius: 22px; padding: 24px; background: radial-gradient(circle at top right, rgba(59, 130, 246, .14) 0, transparent 38%), #ffffff; box-shadow: 0 16px 35px rgba(15, 23, 42, .06); }
  .proc-eyebrow { margin: 0 0 7px; color: hsl(var(--muted-foreground)); font-weight: 800; font-size: 13px; letter-spacing: .05em; text-transform: uppercase; }
  .proc-hero h1 { margin: 0; font-size: 30px; line-height: 1.2; }
  .proc-hero p { max-width: 860px; margin: 9px 0 0; color: hsl(var(--muted-foreground)); }
  .proc-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
  .dashboard-stack { display: grid; gap: 18px; }
  .dashboard-top { display: grid; grid-template-columns: minmax(0, 1.55fr) minmax(320px, .9fr); gap: 18px; align-items: stretch; }
  .hero-panel { display: grid; gap: 22px; }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.3fr) minmax(220px, .7fr); gap: 20px; align-items: center; }
  .hero-kpis { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  .hero-kpi { padding: 16px; border-radius: 18px; background: linear-gradient(180deg, #ffffff 0%, #f6f9fd 100%); border: 1px solid #dae3ef; }
  .hero-kpi-label { font-size: 12px; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: .06em; }
  .hero-kpi-value { margin-top: 8px; font-size: 28px; font-weight: 900; color: #0f172a; }
  .hero-kpi-meta { margin-top: 6px; font-size: 13px; color: #64748b; }
  .spotlight-panel { position: relative; overflow: hidden; display: grid; gap: 16px; }
  .spotlight-panel::after { content: ""; position: absolute; top: -40px; right: -40px; width: 140px; height: 140px; border-radius: 999px; background: radial-gradient(circle, rgba(59, 130, 246, .22) 0%, rgba(59, 130, 246, 0) 70%); pointer-events: none; }
  .spotlight-label { font-size: 12px; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: .06em; }
  .spotlight-value { font-size: 36px; line-height: 1; font-weight: 900; color: #0f172a; }
  .spotlight-copy { color: hsl(var(--muted-foreground)); line-height: 1.65; }
  .mini-list { display: grid; gap: 10px; }
  .mini-list-item { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 14px; background: #f8fbff; border: 1px solid #dbe5f0; }
  .mini-list-dot { width: 12px; height: 12px; border-radius: 999px; }
  .mini-list-dot.pending { background: #f59e0b; }
  .mini-list-dot.submitted { background: #3b82f6; }
  .mini-list-dot.completed { background: #8b5cf6; }
  .mini-list-label { font-size: 13px; font-weight: 700; color: #334155; }
  .mini-list-value { font-size: 15px; font-weight: 900; color: #0f172a; }
  .fw-wrap { max-width: none; margin: 0; padding: 0; }
  .fw-card { background: #ffffff; border: 1px solid #d5deea; border-radius: 18px; padding: 18px; box-shadow: 0 12px 30px rgba(15, 23, 42, .08); margin-bottom: 18px; }
  .fw-title { margin: 0 0 6px; font-size: 26px; font-weight: 800; }
  .fw-subtitle { margin: 0 0 14px; color: hsl(var(--muted-foreground)); }
  .fw-card h2 { margin: 0 0 14px; font-size: 20px; font-weight: 800; color: hsl(var(--foreground)); }
  .fw-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 14px; overflow: hidden; border: 1px solid #d5deea; border-radius: 16px; background: #ffffff; }
  .fw-table th, .fw-table td { border-bottom: 1px solid #e4ebf3; padding: 13px 12px; text-align: left; vertical-align: top; }
  .fw-table thead th { background: #eaf1f8; font-weight: 800; color: #425466; border-bottom: 1px solid #d5deea; }
  .fw-table tbody tr:nth-child(even) td { background: #f8fbff; }
  .fw-table tbody tr:hover td { background: #eef6ff; }
  .fw-table tbody tr:last-child td { border-bottom: none; }
  .fw-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 14px; }
  .fw-form-card { background: linear-gradient(180deg, #ffffff 0%, #f4f8fc 100%); border: 1px solid #cfd9e6; box-shadow: 0 18px 40px rgba(15, 23, 42, .10); }
  .fw-form-header { margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid #d8e1eb; }
  .fw-form-title { margin: 0 0 6px; font-size: 22px; font-weight: 800; }
  .fw-form-copy { margin: 0; color: hsl(var(--muted-foreground)); line-height: 1.6; }
  .fw-form-section { margin-bottom: 18px; padding: 16px; border: 1px solid #d9e3ee; border-radius: 16px; background: #ffffff; box-shadow: inset 0 1px 0 rgba(255, 255, 255, .6); }
  .fw-form-section:last-of-type { margin-bottom: 0; }
  .fw-section-title { margin: 0 0 4px; font-size: 16px; font-weight: 800; }
  .fw-section-copy { margin: 0 0 14px; color: hsl(var(--muted-foreground)); font-size: 14px; }
  .fw-field { display: flex; flex-direction: column; gap: 7px; margin-bottom: 14px; }
  .fw-field:last-child { margin-bottom: 0; }
  .fw-field label { font-weight: 800; font-size: 14px; color: hsl(var(--foreground)); }
  .fw-field input, .fw-field textarea, .fw-field select {
    border: 1px solid #b7c5d6;
    border-radius: 12px;
    padding: 12px 14px;
    background: #ffffff;
    color: #0f172a;
    box-shadow: inset 0 1px 2px rgba(15, 23, 42, .05);
    transition: border-color .16s ease, box-shadow .16s ease, background-color .16s ease;
  }
  .fw-field input::placeholder, .fw-field textarea::placeholder { color: #7b8a9a; }
  .fw-field input:hover, .fw-field textarea:hover, .fw-field select:hover { border-color: #7a9cc6; background: #ffffff; }
  .fw-field input:focus, .fw-field textarea:focus, .fw-field select:focus {
    outline: none;
    border-color: #2563eb;
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, .16), inset 0 1px 1px rgba(15, 23, 42, .04);
  }
  .fw-field-tip { margin: -1px 0 0; color: hsl(var(--muted-foreground)); font-size: 13px; line-height: 1.5; }
  .fw-form-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
  .fw-action-stack { display: flex; flex-wrap: wrap; gap: 10px; }
  .fw-inline-note { margin-top: 14px; padding: 12px 14px; border-radius: 14px; border: 1px solid #dbe5f0; background: #f8fbff; color: #475569; line-height: 1.6; }
  .fw-inline-note strong { color: #0f172a; }
  .fw-btn, button.fw-btn { border: 1px solid #c7d3e0; border-radius: 11px; padding: 9px 13px; background: #ffffff; color: #0f172a; text-decoration: none; font-size: 14px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-weight: 700; }
  .fw-btn.primary, button.fw-btn.primary { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); border-color: hsl(var(--primary)); }
  .fw-btn.danger, button.fw-btn.danger { background: hsl(var(--destructive)); color: hsl(var(--destructive-foreground)); border-color: hsl(var(--destructive)); }
  .fw-badge { display: inline-block; border-radius: 999px; padding: 4px 10px; background: hsl(var(--muted)); color: hsl(var(--foreground)); font-size: 12px; font-weight: 800; border: 1px solid hsl(var(--border)); }
  .fw-badge.pending, .fw-badge.draft, .fw-badge.submitted { background: #fef3c7; color: #92400e; border-color: #fde68a; }
  .fw-badge.approved { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
  .fw-badge.rejected { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
  .fw-badge.completed { background: #dbeafe; color: #1e40af; border-color: #bfdbfe; }
  .fw-flash { border-radius: 13px; padding: 11px 13px; margin-bottom: 16px; font-weight: 700; }
  .fw-flash.success { background: #dcfce7; color: #166534; }
  .fw-flash.error { background: #fee2e2; color: #991b1b; }
  .stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; margin-bottom: 18px; }
  .stat-card { border: 1px solid #d5deea; border-radius: 18px; background: #ffffff; padding: 18px; box-shadow: 0 12px 30px rgba(15, 23, 42, .08); }
  .stat-label { color: hsl(var(--muted-foreground)); font-size: 13px; font-weight: 700; }
  .stat-value { font-size: 30px; font-weight: 900; margin-top: 8px; }
  .status-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
  .content-grid { display: grid; grid-template-columns: 1.25fr .75fr; gap: 16px; align-items: start; }
  .chart-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 18px; }
  .chart-card { display: grid; gap: 16px; }
  .chart-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .chart-meta { font-size: 13px; color: hsl(var(--muted-foreground)); }
  .chart-total { font-size: 28px; font-weight: 900; color: hsl(var(--foreground)); }
  .bar-chart { display: grid; gap: 12px; }
  .bar-row { display: grid; grid-template-columns: 118px 1fr 44px; gap: 12px; align-items: center; }
  .bar-label, .donut-legend-label { font-size: 13px; font-weight: 700; color: hsl(var(--foreground)); }
  .bar-track { position: relative; height: 12px; border-radius: 999px; background: #e7edf5; overflow: hidden; }
  .bar-fill { position: absolute; inset: 0 auto 0 0; border-radius: inherit; }
  .bar-value, .donut-legend-value { font-size: 13px; font-weight: 800; color: hsl(var(--muted-foreground)); text-align: right; }
  .bar-fill.pending { background: linear-gradient(90deg, #f59e0b 0%, #fbbf24 100%); }
  .bar-fill.approved { background: linear-gradient(90deg, #22c55e 0%, #4ade80 100%); }
  .bar-fill.rejected { background: linear-gradient(90deg, #ef4444 0%, #f87171 100%); }
  .bar-fill.draft { background: linear-gradient(90deg, #94a3b8 0%, #cbd5e1 100%); }
  .bar-fill.submitted { background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%); }
  .bar-fill.completed { background: linear-gradient(90deg, #8b5cf6 0%, #a78bfa 100%); }
  .donut-layout { display: grid; grid-template-columns: 180px 1fr; gap: 18px; align-items: center; }
  .donut-chart { width: 180px; height: 180px; margin: 0 auto; position: relative; }
  .donut-chart svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .donut-track { fill: none; stroke: #e7edf5; stroke-width: 18; }
  .donut-segment { fill: none; stroke-width: 18; stroke-linecap: round; }
  .donut-segment.approved { stroke: #22c55e; }
  .donut-segment.submitted { stroke: #3b82f6; }
  .donut-segment.completed { stroke: #8b5cf6; }
  .donut-center { position: absolute; inset: 0; display: grid; place-items: center; text-align: center; }
  .donut-center strong { display: block; font-size: 30px; line-height: 1; }
  .donut-center span { display: block; margin-top: 6px; font-size: 12px; color: hsl(var(--muted-foreground)); }
  .donut-legend { display: grid; gap: 10px; }
  .donut-legend-item { display: grid; grid-template-columns: 14px 1fr auto; gap: 10px; align-items: center; }
  .donut-legend-dot { width: 14px; height: 14px; border-radius: 999px; }
  .donut-legend-dot.approved { background: #22c55e; }
  .donut-legend-dot.submitted { background: #3b82f6; }
  .donut-legend-dot.completed { background: #8b5cf6; }
  .data-grid { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(0, .8fr); gap: 18px; align-items: start; }
  .data-stack { display: grid; gap: 18px; }
  html.dark body { background: #0b1220; }
  html.dark .proc-main { background: linear-gradient(180deg, #0f172a 0%, #111827 100%); }
  html.dark .proc-hero { background: radial-gradient(circle at top right, rgba(96, 165, 250, .20) 0, transparent 40%), #111c2f; border-color: #2c3a52; box-shadow: 0 18px 36px rgba(2, 6, 23, .35); }
  html.dark .hero-kpi { background: linear-gradient(180deg, #162338 0%, #111c2f 100%); border-color: #2c3a52; }
  html.dark .hero-kpi-label, html.dark .spotlight-label, html.dark .chart-meta { color: #93a4b8; }
  html.dark .hero-kpi-value, html.dark .spotlight-value, html.dark .mini-list-value, html.dark .chart-total { color: #f8fafc; }
  html.dark .hero-kpi-meta, html.dark .mini-list-label { color: #c8d5e6; }
  html.dark .mini-list-item { background: #0f1a2b; border-color: #2c3a52; }
  html.dark .fw-card { background: #111c2f; border-color: #2c3a52; box-shadow: 0 16px 34px rgba(2, 6, 23, .32); }
  html.dark .stat-card { background: #111c2f; border-color: #2c3a52; box-shadow: 0 16px 34px rgba(2, 6, 23, .32); }
  html.dark .fw-card h2, html.dark .fw-title, html.dark .fw-form-title, html.dark .fw-section-title { color: #f8fafc; }
  html.dark .fw-table { background: #111c2f; border-color: #31415b; }
  html.dark .fw-table th, html.dark .fw-table td { border-bottom-color: #26354c; color: #e5edf7; }
  html.dark .fw-table thead th { background: #18263b; color: #c8d5e6; border-bottom-color: #31415b; }
  html.dark .fw-table tbody tr:nth-child(even) td { background: #132035; }
  html.dark .fw-table tbody tr:hover td { background: #1a2a41; }
  html.dark .fw-form-card { background: linear-gradient(180deg, #111c2f 0%, #162338 100%); border-color: #31415b; }
  html.dark .fw-form-header { border-bottom-color: #2a3953; }
  html.dark .fw-form-section { background: #0f1a2b; border-color: #2c3a52; }
  html.dark .fw-inline-note { background: #0f1a2b; border-color: #2c3a52; color: #c8d5e6; }
  html.dark .fw-inline-note strong { color: #f8fafc; }
  html.dark .fw-field input, html.dark .fw-field textarea, html.dark .fw-field select { background: #0b1422; border-color: #42536a; color: #f8fafc; }
  html.dark .fw-field input::placeholder, html.dark .fw-field textarea::placeholder { color: #8da0b8; }
  html.dark .fw-field input:hover, html.dark .fw-field textarea:hover, html.dark .fw-field select:hover { border-color: #6c8fbc; }
  html.dark .fw-field input:focus, html.dark .fw-field textarea:focus, html.dark .fw-field select:focus { border-color: #60a5fa; box-shadow: 0 0 0 4px rgba(96, 165, 250, .18), inset 0 1px 1px rgba(15, 23, 42, .08); }
  html.dark .fw-btn, html.dark button.fw-btn { background: #162338; border-color: #31415b; color: #e5edf7; }
  html.dark .bar-track, html.dark .donut-track { background: #1c2a40; stroke: #1c2a40; }
  @media (max-width: 980px) { .proc-shell { grid-template-columns: 1fr; } .proc-sidebar { position: static; height: auto; } .dashboard-top, .hero-grid, .stat-grid, .content-grid, .fw-grid, .chart-grid, .donut-layout, .data-grid { grid-template-columns: 1fr; } .hero-kpis { grid-template-columns: 1fr 1fr; } .fw-table { display:block; overflow-x:auto; } .bar-row { grid-template-columns: 1fr; } .bar-value { text-align: left; } .donut-chart { width: 160px; height: 160px; } }
  @media (max-width: 640px) { .hero-kpis { grid-template-columns: 1fr; } }
</style>
