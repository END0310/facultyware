<script>
  (() => {
    const apply = (dark) => {
      document.documentElement.classList.toggle("dark", dark);
      try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      const label = document.querySelector("[data-theme-label]");
      if (label) label.textContent = dark ? "Mode Terang" : "Mode Gelap";
    };

    document.addEventListener("DOMContentLoaded", () => {
      const currentPath = window.location.pathname.replace(/\/$/, "") || "/";
      document.querySelectorAll(".proc-link").forEach((link) => {
        const href = link.getAttribute("href");
        if (!href) return;
        const linkPath = new URL(href, window.location.origin).pathname.replace(/\/$/, "") || "/";
        const isActive = linkPath === "/procurements"
          ? currentPath === "/procurements" || /^\/procurements\/\d+/.test(currentPath)
          : currentPath === linkPath || (linkPath !== "/home" && currentPath.startsWith(linkPath + "/"));
        if (isActive) link.setAttribute("aria-current", "page");
      });

      const toggle = document.querySelector("[data-theme-toggle]");
      const isDark = document.documentElement.classList.contains("dark");
      apply(isDark);
      if (toggle) toggle.addEventListener("click", () => apply(!document.documentElement.classList.contains("dark")));

      const reportForm = document.querySelector("[data-report-filter-form]");
      const reportTypeSelect = document.querySelector("[data-report-type-select]");
      const reportStatusSelect = document.querySelector("[data-report-status-select]");
      if (reportForm && reportTypeSelect && reportStatusSelect) {
        reportTypeSelect.addEventListener("change", () => {
          reportStatusSelect.value = "";
          reportForm.submit();
        });
      }

      const assetItemSelect = document.querySelector("[data-asset-item-select]");
      if (assetItemSelect) {
        const nameInput = document.querySelector("[data-asset-name]");
        const priceInput = document.querySelector("[data-asset-price]");
        const specificationInput = document.querySelector("[data-asset-specification]");
        const summary = document.querySelector("[data-asset-item-summary]");

        const updateAssetItem = () => {
          const option = assetItemSelect.options[assetItemSelect.selectedIndex];
          if (!option) return;

          const itemName = option.getAttribute("data-name") || "";
          const itemSpecification = option.getAttribute("data-specification") || "Belum ada spesifikasi tambahan.";
          const itemPrice = option.getAttribute("data-estimated-price") || "0";

          if (nameInput) nameInput.value = itemName;
          if (priceInput) priceInput.value = itemPrice;
          if (specificationInput) specificationInput.value = option.getAttribute("data-specification") || "";
          if (summary) summary.innerHTML = `<strong>${itemName || "-"}</strong><span>${itemSpecification}</span>`;
        };

        assetItemSelect.addEventListener("change", updateAssetItem);
      }
    });

    document.addEventListener("basecoat:theme", (event) => {
      const mode = event.detail?.mode;
      apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
    });
  })();
</script>
