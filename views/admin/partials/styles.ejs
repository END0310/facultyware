<style>
  body { margin: 0; background: #f5f7fb; color: hsl(var(--foreground)); font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
  .admin-shell { min-height: 100vh; display: grid; grid-template-columns: 300px 1fr; }
  .admin-sidebar { position: sticky; top: 0; height: 100vh; display: flex; flex-direction: column; gap: 18px; padding: 18px; border-right: 1px solid hsl(var(--border)); background: linear-gradient(180deg, #111827 0%, #1f2937 100%); box-shadow: 8px 0 24px rgba(15, 23, 42, .16); }
  .admin-brand { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 16px; color: #f8fafc; text-decoration: none; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.08); }
  .admin-brand-icon { width: 42px; height: 42px; border-radius: 14px; display: grid; place-items: center; background: #2563eb; color: #eff6ff; }
  .admin-brand-title { font-weight: 800; line-height: 1.2; }
  .admin-brand-subtitle { font-size: 12px; color: #cbd5e1; }
  .admin-nav-title { margin: 8px 10px; font-size: 12px; text-transform: uppercase; letter-spacing: .07em; color: #94a3b8; font-weight: 800; }
  .admin-menu { display: grid; gap: 7px; }
  .admin-link { display: flex; align-items: center; gap: 11px; min-height: 42px; padding: 10px 12px; border-radius: 13px; text-decoration: none; color: #e2e8f0; border: 1px solid transparent; transition: .16s ease; font-size: 14px; font-weight: 600; }
  .admin-link svg { width: 18px; height: 18px; flex: 0 0 18px; }
  .admin-link:hover, .admin-link[aria-current="page"] { background: rgba(255,255,255,.08); color: #ffffff; border-color: rgba(255,255,255,.08); transform: translateX(2px); }
  .admin-sidebar-footer { margin-top: auto; display: grid; gap: 10px; }
  .admin-user { border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 13px; background: rgba(15, 23, 42, .28); }
  .admin-user-name { font-weight: 800; font-size: 14px; color: #f8fafc; }
  .admin-user-email, .admin-user-role { font-size: 12px; color: #cbd5e1; word-break: break-word; margin-top: 2px; }
  .theme-toggle { width: 100%; border: 1px solid rgba(255,255,255,.08); border-radius: 13px; padding: 10px 12px; background: rgba(255,255,255,.04); color: #f8fafc; display: flex; align-items: center; justify-content: center; gap: 9px; cursor: pointer; font-weight: 700; }
  .theme-toggle svg { width: 17px; height: 17px; }
  .logout-link { display: flex; align-items: center; justify-content: center; gap: 9px; border-radius: 13px; padding: 10px 12px; text-decoration: none; background: hsl(var(--destructive)); color: hsl(var(--destructive-foreground)); font-weight: 800; }
  .logout-link svg { width: 17px; height: 17px; }
  .admin-main { min-width: 0; padding: 28px; background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%); }
  .fw-card { background: #ffffff; border: 1px solid #d5deea; border-radius: 18px; padding: 18px; box-shadow: 0 12px 30px rgba(15, 23, 42, .08); margin-bottom: 18px; }
  .fw-title { margin: 0 0 6px; font-size: 26px; font-weight: 800; }
  .fw-subtitle { margin: 0 0 14px; color: hsl(var(--muted-foreground)); }
  .fw-card h2 { margin: 0 0 14px; font-size: 20px; font-weight: 800; color: hsl(var(--foreground)); }
  .fw-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 14px; overflow: hidden; border: 1px solid #d5deea; border-radius: 16px; background: #ffffff; }
  .fw-table th, .fw-table td { border-bottom: 1px solid #e4ebf3; padding: 13px 12px; text-align: left; vertical-align: top; }
  .fw-table thead th { background: #eaf1f8; font-weight: 800; color: #425466; border-bottom: 1px solid #d5deea; }
  .fw-table tbody tr:nth-child(even) td { background: #f8fbff; }
  .fw-table tbody tr:hover td { background: #eef6ff; }
  .fw-table tbody tr:last-child td { border-bottom: none; }
  .fw-form-card { background: linear-gradient(180deg, #ffffff 0%, #f4f8fc 100%); border: 1px solid #cfd9e6; box-shadow: 0 18px 40px rgba(15, 23, 42, .10); }
  .fw-field { display: flex; flex-direction: column; gap: 7px; margin-bottom: 14px; }
  .fw-field:last-child { margin-bottom: 0; }
  .fw-field label { font-weight: 800; font-size: 14px; color: hsl(var(--foreground)); }
  .fw-field input { border: 1px solid #b7c5d6; border-radius: 12px; padding: 12px 14px; background: #ffffff; color: #0f172a; box-shadow: inset 0 1px 2px rgba(15, 23, 42, .05); transition: border-color .16s ease, box-shadow .16s ease, background-color .16s ease; }
  .fw-field input:hover { border-color: #7a9cc6; }
  .fw-field input:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 4px rgba(37, 99, 235, .16), inset 0 1px 1px rgba(15, 23, 42, .04); }
  .fw-form-actions, .fw-action-stack { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
  .fw-btn, button.fw-btn { border: 1px solid #c7d3e0; border-radius: 11px; padding: 9px 13px; background: #ffffff; color: #0f172a; text-decoration: none; font-size: 14px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-weight: 700; }
  .fw-btn.primary, button.fw-btn.primary { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); border-color: hsl(var(--primary)); }
  .fw-flash { border-radius: 13px; padding: 11px 13px; margin-bottom: 16px; font-weight: 700; }
  .fw-flash.success { background: #dcfce7; color: #166534; }
  .fw-flash.error { background: #fee2e2; color: #991b1b; }
  html.dark body { background: #0b1220; }
  html.dark .admin-main { background: linear-gradient(180deg, #0f172a 0%, #111827 100%); }
  html.dark .fw-card { background: #111c2f; border-color: #2c3a52; box-shadow: 0 16px 34px rgba(2, 6, 23, .32); }
  html.dark .fw-card h2, html.dark .fw-title { color: #f8fafc; }
  html.dark .fw-table { background: #111c2f; border-color: #31415b; }
  html.dark .fw-table th, html.dark .fw-table td { border-bottom-color: #26354c; color: #e5edf7; }
  html.dark .fw-table thead th { background: #18263b; color: #c8d5e6; border-bottom-color: #31415b; }
  html.dark .fw-table tbody tr:nth-child(even) td { background: #132035; }
  html.dark .fw-table tbody tr:hover td { background: #1a2a41; }
  html.dark .fw-form-card { background: linear-gradient(180deg, #111c2f 0%, #162338 100%); border-color: #31415b; }
  html.dark .fw-field input { background: #0b1422; border-color: #42536a; color: #f8fafc; }
  html.dark .fw-field input:hover { border-color: #6c8fbc; }
  html.dark .fw-field input:focus { border-color: #60a5fa; box-shadow: 0 0 0 4px rgba(96, 165, 250, .18), inset 0 1px 1px rgba(15, 23, 42, .08); }
  html.dark .fw-btn, html.dark button.fw-btn { background: #162338; border-color: #31415b; color: #e5edf7; }
  @media (max-width: 980px) { .admin-shell { grid-template-columns: 1fr; } .admin-sidebar { position: static; height: auto; } .fw-table { display:block; overflow-x:auto; } }
</style>
