<%- include('../partials/header', { title, flash }) %>
<div class="fw-card">
  <h1 class="fw-title">Manajemen Akun</h1>
  <p class="fw-subtitle">Halaman ini hanya dapat diakses admin untuk mengelola nama, email, dan reset password akun.</p>
</div>

<div class="fw-card" style="margin-bottom:16px;">
  <form method="GET" action="/admin/users" style="display:flex;gap:8px;align-items:center;">
    <input type="text" name="search" value="<%= search %>" placeholder="Cari nama atau email..." class="fw-input" style="flex:1;max-width:320px;" />
    <button type="submit" class="fw-btn primary">Cari</button>
    <% if (search) { %>
    <a href="/admin/users" class="fw-btn">Reset</a>
    <% } %>
  </form>
</div>

<div class="fw-card">
  <table class="fw-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Nama</th>
        <th>Email</th>
        <th>Role</th>
        <th>Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% if (!users.length) { %>
        <tr><td colspan="5"><%= search ? 'Tidak ada hasil untuk "' + search + '"' : 'Belum ada akun.' %></td></tr>
      <% } %>
      <% users.forEach((user) => { %>
        <tr>
          <td><%= user.id %></td>
          <td><%= user.name || '-' %></td>
          <td><%= user.email || '-' %></td>
          <td><%= user.roles || '-' %></td>
          <td>
            <div class="fw-action-stack">
              <a class="fw-btn" href="/admin/users/<%= user.id %>/edit">Edit</a>
              <a class="fw-btn primary" href="/admin/users/<%= user.id %>/reset-password">Reset Password</a>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;font-size:14px;color:#6b7280;">
    <span>Menampilkan <strong><%= users.length %></strong> dari <strong><%= totalItems %></strong> akun</span>
    <% if (totalPages > 1) { %>
    <div style="display:flex;gap:8px;align-items:center;">
      <a href="/admin/users?page=<%= Math.max(1, currentPage - 1) %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
         class="fw-btn" <%= currentPage <= 1 ? 'style="pointer-events:none;opacity:0.5"' : '' %>>← Prev</a>
      <span>Hal <strong><%= currentPage %></strong> / <%= totalPages %></span>
      <a href="/admin/users?page=<%= Math.min(totalPages, currentPage + 1) %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
         class="fw-btn" <%= currentPage >= totalPages ? 'style="pointer-events:none;opacity:0.5"' : '' %>>Next →</a>
    </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
