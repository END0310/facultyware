<%- include('../partials/header', { title, flash }) %>
<div class="fw-card">
  <h1 class="fw-title">Edit Akun</h1>
  <p class="fw-subtitle">Perbarui nama dan email akun. Role saat ini: <strong><%= user.roles || '-' %></strong></p>
</div>
<form class="fw-card fw-form-card" method="post" action="/admin/users/<%= user.id %>/edit">
  <% if (errors.length) { %>
    <div class="fw-flash error">
      <ul style="margin:0;padding-left:18px;">
        <% errors.forEach((error) => { %><li><%= error %></li><% }) %>
      </ul>
    </div>
  <% } %>
  <div class="fw-field">
    <label>Nama</label>
    <input type="text" name="name" required value="<%= old.name || '' %>">
  </div>
  <div class="fw-field">
    <label>Email</label>
    <input type="email" name="email" required value="<%= old.email || '' %>">
  </div>
  <div class="fw-form-actions">
    <a class="fw-btn" href="/admin/users">Kembali</a>
    <button class="fw-btn primary" type="submit">Simpan Perubahan</button>
  </div>
</form>
<%- include('../partials/footer') %>
