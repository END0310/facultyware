<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
        document.addEventListener("basecoat:theme", (e) => {
          const mode = e.detail?.mode;
          const dark = mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark");
          document.documentElement.classList.toggle("dark", dark);
          try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
        });
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edit Usulan — Facultyware</title>

    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="stylesheet" href="/assets/styles.css" />

    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="/assets/js/sidebar.js?v=0.3.11" defer></script>
  </head>

  <body>
    <script>
      (() => {
        document.addEventListener("DOMContentLoaded", () => {
          const sidebar = document.getElementById("sidebar");
          if (!sidebar) return;
          const updateCurrentLinks = () => {
            const currentPath = window.location.pathname.replace(/\/$/, "");
            sidebar.querySelectorAll("a").forEach((item) => {
              const href = item.getAttribute("href");
              if (!href) return;
              try {
                const url = new URL(href, window.location.origin);
                if (url.pathname.replace(/\/$/, "") === currentPath) {
                  item.setAttribute("aria-current", "page");
                } else {
                  item.removeAttribute("aria-current");
                }
              } catch (_) {}
            });
          };
          updateCurrentLinks();
        });
      })();
    </script>

    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
      <nav aria-label="Sidebar navigation">
        <header>
          <a href="/home" class="btn-ghost p-2 h-12 w-full justify-start">
            <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <div class="grid flex-1 text-left text-sm leading-tight ml-2">
              <span class="truncate font-medium">Facultyware</span>
              <span class="truncate text-xs text-muted-foreground">Pengadaan Barang</span>
            </div>
          </a>
        </header>

        <div class="scrollbar p-2 flex-1 overflow-y-auto">
          <div role="group" aria-labelledby="group-pengadaan">
            <h3 id="group-pengadaan" class="px-2 py-1 text-xs font-semibold text-muted-foreground uppercase tracking-wider">Pengadaan Barang</h3>
            <ul class="mt-1 space-y-0.5">
              <li>
                <a href="/usulan" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                  Daftar Usulan
                </a>
              </li>
              <li>
                <a href="/usulan/create" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  Buat Usulan Baru
                </a>
              </li>
              <li>
                <a href="/usulan/laporan/pdf" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  Unduh Laporan PDF
                </a>
              </li>
            </ul>
          </div>
        </div>

        <footer class="p-2 border-t border-sidebar-border">
          <div class="flex items-center gap-2 rounded-md px-2 py-1.5">
            <div class="flex aspect-square size-8 items-center justify-center rounded-full bg-muted text-sm font-medium">
              <%= user ? user.charAt(0).toUpperCase() : 'U' %>
            </div>
            <div class="grid flex-1 text-left text-sm leading-tight">
              <span class="truncate font-medium"><%= user || 'Pengguna' %></span>
              <span class="truncate text-xs text-muted-foreground">Ketua Departemen</span>
            </div>
            <a href="/logout" class="btn-sm-ghost px-2" data-tooltip="Keluar" data-side="top">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </a>
          </div>
        </footer>
      </nav>
    </aside>

    <!-- Main content -->
    <main id="content">
      <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
        <div class="flex h-14 w-full items-center gap-2 px-4">
          <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" aria-label="Toggle sidebar" data-tooltip="Toggle sidebar" data-side="bottom" data-align="start" class="btn-sm-icon-ghost mr-auto size-7 -ml-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
          </button>
          <button type="button" aria-label="Toggle dark mode" data-tooltip="Toggle dark mode" data-side="bottom" onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))" class="btn-icon-outline size-8">
            <span class="hidden dark:block"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2m-7.07-14.07 1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2m-4.93 7.07-1.41-1.41M6.34 6.34 4.93 4.93"/></svg></span>
            <span class="block dark:hidden"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg></span>
          </button>
        </div>
      </header>

      <div class="p-4 md:p-6 xl:p-8">
        <div class="max-w-screen-md mx-auto">

          <!-- Breadcrumb — kembali ke /usulan bukan ke detail (tidak ada route detail) -->
          <nav class="flex items-center gap-1.5 text-sm text-muted-foreground mb-4">
            <a href="/usulan" class="hover:text-foreground transition-colors">Usulan Pengadaan</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="text-foreground font-medium truncate max-w-[200px]"><%= procurement.title %></span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="text-foreground font-medium">Edit</span>
          </nav>

          <!-- Error validation -->
          <% if (errors && errors.length > 0) { %>
          <div class="alert alert-destructive mb-4" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <div>
              <p class="font-medium">Terdapat kesalahan:</p>
              <ul class="mt-1 list-disc list-inside text-sm">
                <% errors.forEach(function(err) { %><li><%= err %></li><% }) %>
              </ul>
            </div>
          </div>
          <% } %>

          <!-- Edit form card -->
          <div class="card">
            <header>
              <div class="flex items-start justify-between gap-2">
                <div>
                  <h1 class="text-lg font-semibold">Edit Usulan Pengadaan</h1>
                  <p class="text-muted-foreground text-sm font-mono mt-0.5"><%= procurement.request_number %></p>
                </div>
                <%
                  const statusMap = {
                    draft:     { label: 'Draft',     cls: 'badge-muted' },
                    submitted: { label: 'Diajukan',  cls: 'badge-secondary' },
                    approved:  { label: 'Disetujui', cls: 'badge-default' },
                    rejected:  { label: 'Ditolak',   cls: 'badge-destructive' },
                    completed: { label: 'Selesai',   cls: 'badge-secondary' }
                  };
                  const s = statusMap[procurement.status] || { label: procurement.status, cls: 'badge-outline' };
                %>
                <span class="badge <%= s.cls %>"><%= s.label %></span>
              </div>
            </header>

            <section>
              <form class="form grid gap-6" action="/usulan/<%= procurement.id %>/update" method="POST" id="form-edit">

                <!-- Judul -->
                <div class="grid gap-2">
                  <label for="title">
                    Judul Usulan
                    <span class="text-destructive ml-0.5">*</span>
                  </label>
                  <input
                    type="text"
                    id="title"
                    name="title"
                    class="w-full"
                    value="<%= procurement.title %>"
                    required
                    <%= procurement.status !== 'draft' ? 'disabled' : '' %>
                  />
                </div>

                <!-- Divider -->
                <div class="flex items-center gap-3">
                  <div class="h-px flex-1 bg-border"></div>
                  <span class="text-xs text-muted-foreground font-medium uppercase tracking-wider">Daftar Barang</span>
                  <div class="h-px flex-1 bg-border"></div>
                </div>

                <!-- Item rows dari database -->
                <div id="items-container" class="grid gap-4">
                  <% if (items && items.length > 0) { %>
                    <% items.forEach(function(item, idx) { %>
                    <div class="item-row grid gap-3 p-4 rounded-lg border bg-muted/30" data-index="<%= idx %>">
                      <div class="flex items-center justify-between">
                        <span class="text-sm font-medium">Barang #<span class="item-number"><%= idx + 1 %></span></span>
                        <% if (procurement.status === 'draft' && items.length > 1) { %>
                        <button type="button" class="btn-sm-ghost text-destructive" onclick="removeItem(this)">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                          Hapus
                        </button>
                        <% } %>
                      </div>
                      <div class="grid gap-2">
                        <label>Nama Barang <span class="text-destructive">*</span></label>
                        <input type="text" name="item_names[]" class="w-full" value="<%= item.name %>" required <%= procurement.status !== 'draft' ? 'disabled' : '' %> />
                      </div>
                      <div class="grid gap-2">
                        <label>Spesifikasi</label>
                        <textarea name="item_specs[]" class="w-full" rows="2" <%= procurement.status !== 'draft' ? 'disabled' : '' %>><%= item.specification || '' %></textarea>
                      </div>
                      <div class="grid grid-cols-2 gap-3">
                        <div class="grid gap-2">
                          <label>Jumlah <span class="text-destructive">*</span></label>
                          <input type="number" name="item_quantities[]" class="w-full" min="1" value="<%= item.quantity %>" required oninput="updateTotal()" <%= procurement.status !== 'draft' ? 'disabled' : '' %> />
                        </div>
                        <div class="grid gap-2">
                          <label>Harga Satuan (Rp) <span class="text-destructive">*</span></label>
                          <input type="number" name="item_prices[]" class="w-full" min="0" value="<%= item.estimated_price || 0 %>" required oninput="updateTotal()" <%= procurement.status !== 'draft' ? 'disabled' : '' %> />
                        </div>
                      </div>
                    </div>
                    <% }) %>
                  <% } else { %>
                    <!-- Baris kosong jika tidak ada item -->
                    <div class="item-row grid gap-3 p-4 rounded-lg border bg-muted/30" data-index="0">
                      <div class="flex items-center justify-between">
                        <span class="text-sm font-medium">Barang #<span class="item-number">1</span></span>
                      </div>
                      <div class="grid gap-2">
                        <label>Nama Barang <span class="text-destructive">*</span></label>
                        <input type="text" name="item_names[]" class="w-full" placeholder="Nama barang" required />
                      </div>
                      <div class="grid gap-2">
                        <label>Spesifikasi</label>
                        <textarea name="item_specs[]" class="w-full" rows="2" placeholder="Spesifikasi"></textarea>
                      </div>
                      <div class="grid grid-cols-2 gap-3">
                        <div class="grid gap-2">
                          <label>Jumlah <span class="text-destructive">*</span></label>
                          <input type="number" name="item_quantities[]" class="w-full" min="1" value="1" required oninput="updateTotal()" />
                        </div>
                        <div class="grid gap-2">
                          <label>Harga Satuan (Rp) <span class="text-destructive">*</span></label>
                          <input type="number" name="item_prices[]" class="w-full" min="0" placeholder="0" required oninput="updateTotal()" />
                        </div>
                      </div>
                    </div>
                  <% } %>
                </div>

                <!-- Tambah barang (hanya jika masih draft) -->
                <% if (procurement.status === 'draft') { %>
                <button type="button" id="btn-add-item" class="btn-outline w-full">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  Tambah Barang
                </button>
                <% } %>

                <!-- Total estimasi -->
                <div class="flex items-center justify-between p-4 rounded-lg border bg-muted/50">
                  <span class="text-sm font-medium">Total Estimasi Biaya</span>
                  <span id="total-preview" class="font-bold text-lg">
                    Rp <%=
                      (items && items.length > 0)
                        ? items.reduce(function(sum, i) { return sum + (i.quantity * parseFloat(i.estimated_price || 0)); }, 0).toLocaleString('id-ID')
                        : '0'
                    %>
                  </span>
                </div>

                <!-- Actions -->
                <footer class="flex items-center justify-between gap-3 pt-2">
                  <!-- Kembali ke daftar (bukan detail karena tidak ada route-nya) -->
                  <a href="/usulan" class="btn-ghost">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    Kembali
                  </a>
                  <% if (procurement.status === 'draft') { %>
                  <div class="flex items-center gap-3">
                    <button type="submit" name="action" value="draft" class="btn-outline">
                      Simpan Draft
                    </button>
                    <button type="submit" name="action" value="submit" class="btn">
                      Ajukan Usulan
                    </button>
                  </div>
                  <% } %>
                </footer>
              </form>
            </section>
          </div>

        </div>
      </div>
    </main>

    <div id="toaster" class="toaster"></div>

    <% if (procurement.status === 'draft') { %>
    <script>
      var itemCount = document.querySelectorAll('.item-row').length;

      var addBtn = document.getElementById('btn-add-item');
      if (addBtn) {
        addBtn.addEventListener('click', function() {
          var idx = itemCount;
          var container = document.getElementById('items-container');
          var row = document.createElement('div');
          row.className = 'item-row grid gap-3 p-4 rounded-lg border bg-muted/30';
          row.dataset.index = idx;
          row.innerHTML = [
            '<div class="flex items-center justify-between">',
            '  <span class="text-sm font-medium">Barang #<span class="item-number">' + (idx + 1) + '</span></span>',
            '  <button type="button" class="btn-sm-ghost text-destructive" onclick="removeItem(this)">',
            '    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>',
            '    Hapus',
            '  </button>',
            '</div>',
            '<div class="grid gap-2">',
            '  <label>Nama Barang <span class="text-destructive">*</span></label>',
            '  <input type="text" name="item_names[]" class="w-full" placeholder="Nama barang" required />',
            '</div>',
            '<div class="grid gap-2">',
            '  <label>Spesifikasi</label>',
            '  <textarea name="item_specs[]" class="w-full" rows="2" placeholder="Spesifikasi"></textarea>',
            '</div>',
            '<div class="grid grid-cols-2 gap-3">',
            '  <div class="grid gap-2">',
            '    <label>Jumlah <span class="text-destructive">*</span></label>',
            '    <input type="number" name="item_quantities[]" class="w-full" min="1" value="1" required oninput="updateTotal()" />',
            '  </div>',
            '  <div class="grid gap-2">',
            '    <label>Harga Satuan (Rp) <span class="text-destructive">*</span></label>',
            '    <input type="number" name="item_prices[]" class="w-full" min="0" placeholder="0" required oninput="updateTotal()" />',
            '  </div>',
            '</div>'
          ].join('');
          container.appendChild(row);
          itemCount++;
          renumberItems();
        });
      }

      function removeItem(btn) {
        var rows = document.querySelectorAll('.item-row');
        if (rows.length <= 1) return;
        btn.closest('.item-row').remove();
        renumberItems();
        updateTotal();
      }

      function renumberItems() {
        document.querySelectorAll('.item-number').forEach(function(el, i) {
          el.textContent = i + 1;
        });
      }

      function updateTotal() {
        var total = 0;
        document.querySelectorAll('.item-row').forEach(function(row) {
          var qInput = row.querySelector('input[name="item_quantities[]"]');
          var pInput = row.querySelector('input[name="item_prices[]"]');
          var qty   = qInput ? (parseFloat(qInput.value) || 0) : 0;
          var price = pInput ? (parseFloat(pInput.value) || 0) : 0;
          total += qty * price;
        });
        document.getElementById('total-preview').textContent = 'Rp ' + total.toLocaleString('id-ID');
      }
    </script>
    <% } %>
  </body>
</html>
