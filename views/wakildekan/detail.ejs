<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
        document.addEventListener("basecoat:theme", (e) => {
          const mode = e.detail?.mode;
          const dark = mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark");
          document.documentElement.classList.toggle("dark", dark);
          try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
        });
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware</title>

    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="stylesheet" href="/assets/styles.css" />

    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="/assets/js/sidebar.js?v=0.3.11" defer></script>
  </head>

  <body>
    <script>
      (() => {
        document.addEventListener("DOMContentLoaded", () => {
          const sidebar = document.getElementById("sidebar");
          if (!sidebar) return;
          const updateCurrentLinks = () => {
            const currentPath = window.location.pathname.replace(/\/$/, "");
            sidebar.querySelectorAll("a").forEach((item) => {
              const href = item.getAttribute("href");
              if (!href) return;
              try {
                const url = new URL(href, window.location.origin);
                if (currentPath.startsWith(url.pathname.replace(/\/$/, ""))) {
                  item.setAttribute("aria-current", "page");
                } else {
                  item.removeAttribute("aria-current");
                }
              } catch (_) {}
            });
          };
          updateCurrentLinks();
        });
      })();
    </script>

    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
      <nav aria-label="Sidebar navigation">
        <header>
          <a href="/wakildekan/permohonan" class="btn-ghost p-2 h-12 w-full justify-start">
            <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <div class="grid flex-1 text-left text-sm leading-tight ml-2">
              <span class="truncate font-medium">Facultyware</span>
              <span class="truncate text-xs text-muted-foreground">Wakil Dekan</span>
            </div>
          </a>
        </header>

        <div class="scrollbar p-2 flex-1 overflow-y-auto">
          <div role="group" aria-labelledby="group-wakildekan">
            <h3 id="group-wakildekan" class="px-2 py-1 text-xs font-semibold text-muted-foreground uppercase tracking-wider">Permohonan Pengadaan</h3>
            <ul class="mt-1 space-y-0.5">
              <li>
                <a href="/wakildekan/dashboard" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
                  Dashboard
                </a>
              </li>
              <li>
                <a href="/wakildekan/permohonan" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                  Daftar Permohonan
                </a>
              </li>
              <li>
                <a href="/wakildekan/riwayat" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
                  Riwayat Keputusan
                </a>
              </li>
              <li>
                <a href="/wakildekan/api/permohonan" target="_blank" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent text-muted-foreground">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                  API JSON
                </a>
              </li>
            </ul>
          </div>
        </div>

        <footer class="p-2 border-t border-sidebar-border">
          <div class="flex items-center gap-2 rounded-md px-2 py-1.5">
            <div class="flex aspect-square size-8 items-center justify-center rounded-full bg-muted text-sm font-medium">
              <%= locals.username ? locals.username.charAt(0).toUpperCase() : 'W' %>
            </div>
            <div class="grid flex-1 text-left text-sm leading-tight">
              <span class="truncate font-medium"><%= locals.username || 'Wakil Dekan' %></span>
              <span class="truncate text-xs text-muted-foreground">Wakil Dekan</span>
            </div>
            <a href="/logout" class="btn-sm-ghost px-2" data-tooltip="Keluar" data-side="top">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </a>
          </div>
        </footer>
      </nav>
    </aside>

    <main id="content">
      <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
        <div class="flex h-14 w-full items-center gap-2 px-4">
          <button
            type="button"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar"
            class="btn-sm-icon-ghost mr-auto size-7 -ml-1.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"/>
              <path d="M9 3v18"/>
            </svg>
          </button>

          <button
            type="button"
            aria-label="Toggle dark mode"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
            class="btn-icon-outline size-8"
          >
            <span class="hidden dark:block">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2m-7.07-14.07 1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2m-4.93 7.07-1.41-1.41M6.34 6.34 4.93 4.93"/></svg>
            </span>
            <span class="block dark:hidden">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            </span>
          </button>
        </div>
      </header>

      <div class="p-4 md:p-6 xl:p-8">
        <div class="max-w-screen-lg mx-auto">
          
          <div class="mb-6">
            <a href="/wakildekan/permohonan" class="btn-sm-outline inline-flex items-center gap-1.5 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              Kembali
            </a>
            <h1 class="text-2xl font-bold tracking-tight"><%= title %></h1>
          </div>

          <% if (locals.errorMessage) { %>
          <div class="alert alert-destructive mb-4" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span><%= errorMessage %></span>
          </div>
          <% } %>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Informasi Permohonan -->
            <div class="col-span-1 lg:col-span-1">
              <div class="card" style="padding: 1.75rem 2rem;">
                <h3 class="font-semibold text-lg mb-5 pb-3 border-b">Informasi Permohonan</h3>
                <dl class="space-y-5 text-sm">
                  <div class="flex flex-col gap-1">
                    <dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Nomor Request</dt>
                    <dd class="font-mono font-semibold text-base"><%= permohonan.request_number %></dd>
                  </div>
                  <div class="flex flex-col gap-1">
                    <dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Judul Pengadaan</dt>
                    <dd class="font-semibold"><%= permohonan.title %></dd>
                  </div>
                  <div class="flex flex-col gap-1">
                    <dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Diajukan Oleh</dt>
                    <dd class="font-medium"><%= permohonan.created_by_name %></dd>
                  </div>
                  <div class="flex flex-col gap-1">
                    <dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Tanggal Pengajuan</dt>
                    <dd class="font-medium"><%= new Date(permohonan.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></dd>
                  </div>
                  <div class="flex flex-col gap-1">
                    <dt class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Status</dt>
                    <dd class="mt-0.5">
                      <%
                        let badgeCls = 'badge-outline';
                        let label = permohonan.status;
                        if (permohonan.status === 'submitted') { badgeCls = 'badge-secondary'; label = 'Diajukan'; }
                        else if (permohonan.status === 'approved') { badgeCls = 'badge-default'; label = 'Disetujui'; }
                        else if (permohonan.status === 'rejected') { badgeCls = 'badge-destructive'; label = 'Ditolak'; }
                        else if (permohonan.status === 'draft') { badgeCls = 'badge-muted'; label = 'Draft'; }
                        else if (permohonan.status === 'completed') { badgeCls = 'badge-secondary'; label = 'Selesai'; }
                      %>
                      <span class="badge <%= badgeCls %>"><%= label %></span>
                    </dd>
                  </div>
                </dl>

                <% if (permohonan.status === 'submitted') { %>
                <div class="mt-6 flex flex-col gap-3 pt-6 border-t">
                  <form id="form-approve" action="/wakildekan/permohonan/<%= permohonan.id %>/approve" method="POST">
                    <button type="button" onclick="openConfirmDialog('approve')" class="btn w-full gap-2" style="background-color: #16a34a; border-color: #16a34a; color: white;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      Setujui Permohonan
                    </button>
                  </form>
                  <form id="form-reject" action="/wakildekan/permohonan/<%= permohonan.id %>/reject" method="POST">
                    <button type="button" onclick="openConfirmDialog('reject')" class="btn-destructive w-full gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      Tolak Permohonan
                    </button>
                  </form>
                </div>
                <% } %>
              </div>
            </div>

            <!-- Item List -->
            <div class="col-span-1 lg:col-span-2">
              <div class="card p-0 overflow-hidden">
                <div class="border-b bg-muted/20" style="padding: 1.25rem 2rem;">
                  <h3 class="font-semibold text-lg">Daftar Barang</h3>
                  <p class="text-xs text-muted-foreground mt-0.5">Rincian barang yang diminta dalam permohonan ini</p>
                </div>
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b bg-muted/50">
                        <th class="py-3 text-left font-medium text-muted-foreground" style="padding-left:2rem; width:3.5rem;">No</th>
                        <th class="px-4 py-3 text-left font-medium text-muted-foreground">Nama Barang</th>
                        <th class="px-4 py-3 text-left font-medium text-muted-foreground">Spesifikasi</th>
                        <th class="px-4 py-3 text-right font-medium text-muted-foreground" style="width:5rem;">Jumlah</th>
                        <th class="px-4 py-3 text-right font-medium text-muted-foreground">Estimasi Harga</th>
                        <th class="py-3 text-right font-medium text-muted-foreground" style="padding-right:2rem;">Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% let grandTotal = 0; %>
                      <% if (items && items.length > 0) { %>
                        <% items.forEach((item, i) => { 
                             const itemTotal = item.quantity * item.estimated_price;
                             grandTotal += itemTotal;
                        %>
                        <tr class="border-b last:border-0 hover:bg-muted/30 transition-colors">
                          <td class="py-3 text-muted-foreground" style="padding-left:2rem;"><%= i + 1 %></td>
                          <td class="px-4 py-3 font-medium"><%= item.name %></td>
                          <td class="px-4 py-3 text-muted-foreground"><%= item.specification || '-' %></td>
                          <td class="px-4 py-3 text-right tabular-nums"><%= item.quantity %></td>
                          <td class="px-4 py-3 text-right tabular-nums"><%= Number(item.estimated_price).toLocaleString('id-ID', { style: 'currency', currency: 'IDR' }) %></td>
                          <td class="py-3 text-right tabular-nums font-medium" style="padding-right:2rem;"><%= Number(itemTotal).toLocaleString('id-ID', { style: 'currency', currency: 'IDR' }) %></td>
                        </tr>
                        <% }) %>
                      <% } else { %>
                        <tr>
                          <td colspan="6" class="py-10 text-center text-muted-foreground" style="padding-left:2rem; padding-right:2rem;">Tidak ada item</td>
                        </tr>
                      <% } %>
                    </tbody>
                  </table>
                </div>
                <div class="border-t bg-muted/20 flex justify-between items-center" style="padding: 1rem 2rem;">
                  <span class="font-semibold text-muted-foreground">Total Estimasi Keseluruhan</span>
                  <span class="text-lg font-bold tabular-nums text-foreground"><%= Number(grandTotal).toLocaleString('id-ID', { style: 'currency', currency: 'IDR' }) %></span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </main>

    <!-- Custom Confirmation Modal -->
    <% if (permohonan.status === 'submitted') { %>
    <div id="confirm-overlay" style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center; background:rgba(0,0,0,0.6); backdrop-filter:blur(4px);">
      <div id="confirm-modal" style="background:var(--background, #1c1c1c); border:1px solid var(--border, #333); border-radius:1rem; width:100%; max-width:420px; margin:1rem; box-shadow:0 25px 50px -12px rgba(0,0,0,0.5); overflow:hidden;">
        <div style="padding:2rem 2rem 1.5rem; text-align:center;">
          <div id="dialog-icon-container" style="display:inline-flex; align-items:center; justify-content:center; width:56px; height:56px; border-radius:50%; margin-bottom:1rem;"></div>
          <h3 id="dialog-title" style="font-size:1.125rem; font-weight:600; margin:0 0 0.5rem; color:var(--foreground, #fff);"></h3>
          <p id="dialog-description" style="font-size:0.875rem; color:var(--muted-foreground, #999); margin:0; line-height:1.6; max-width:320px; margin-left:auto; margin-right:auto;"></p>
        </div>
        <div style="display:flex; justify-content:center; gap:0.75rem; padding:1.25rem 2rem; border-top:1px solid var(--border, #333); background:var(--muted, rgba(255,255,255,0.03));">
          <button type="button" id="dialog-cancel" class="btn-outline" style="padding:0.5rem 1.5rem; min-width:100px;">Batal</button>
          <button type="button" id="dialog-confirm" class="btn" style="padding:0.5rem 1.5rem; min-width:120px;">Konfirmasi</button>
        </div>
      </div>
    </div>

    <style>
      #confirm-overlay.show {
        display: flex !important;
        animation: overlay-in 0.2s ease-out forwards;
      }
      #confirm-overlay.show #confirm-modal {
        animation: modal-in 0.25s ease-out forwards;
      }
      #confirm-overlay.hiding {
        animation: overlay-out 0.15s ease-in forwards;
      }
      #confirm-overlay.hiding #confirm-modal {
        animation: modal-out 0.15s ease-in forwards;
      }
      @keyframes overlay-in { from { opacity: 0; } to { opacity: 1; } }
      @keyframes overlay-out { from { opacity: 1; } to { opacity: 0; } }
      @keyframes modal-in { from { opacity: 0; transform: scale(0.9) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
      @keyframes modal-out { from { opacity: 1; transform: scale(1) translateY(0); } to { opacity: 0; transform: scale(0.9) translateY(10px); } }
    </style>

    <script>
      const overlay = document.getElementById('confirm-overlay');
      const dialogTitle = document.getElementById('dialog-title');
      const dialogDesc = document.getElementById('dialog-description');
      const dialogConfirm = document.getElementById('dialog-confirm');
      const dialogCancel = document.getElementById('dialog-cancel');
      const dialogIconContainer = document.getElementById('dialog-icon-container');
      let pendingAction = null;

      function openConfirmDialog(action) {
        pendingAction = action;
        const approveIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        const rejectIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>';
        const sm = (s) => s.replace(/width="\d+"/,'width="16"').replace(/height="\d+"/,'height="16"');

        if (action === 'approve') {
          dialogTitle.textContent = 'Setujui Permohonan';
          dialogDesc.textContent = 'Apakah Anda yakin ingin menyetujui permohonan pengadaan ini? Tindakan ini akan mengubah status menjadi disetujui.';
          dialogConfirm.className = 'btn';
          dialogConfirm.style.cssText = 'padding:0.5rem 1.5rem; min-width:120px; background:#16a34a; border-color:#16a34a; color:#fff; display:inline-flex; align-items:center; gap:0.5rem;';
          dialogConfirm.innerHTML = sm(approveIcon) + ' Ya, Setujui';
          dialogIconContainer.style.cssText = 'display:inline-flex; align-items:center; justify-content:center; width:56px; height:56px; border-radius:50%; margin-bottom:1rem; background:rgba(22,163,74,0.15); color:#22c55e;';
          dialogIconContainer.innerHTML = approveIcon;
        } else {
          dialogTitle.textContent = 'Tolak Permohonan';
          dialogDesc.textContent = 'Apakah Anda yakin ingin menolak permohonan pengadaan ini? Tindakan ini akan mengubah status menjadi ditolak.';
          dialogConfirm.className = 'btn-destructive';
          dialogConfirm.style.cssText = 'padding:0.5rem 1.5rem; min-width:120px; display:inline-flex; align-items:center; gap:0.5rem;';
          dialogConfirm.innerHTML = sm(rejectIcon) + ' Ya, Tolak';
          dialogIconContainer.style.cssText = 'display:inline-flex; align-items:center; justify-content:center; width:56px; height:56px; border-radius:50%; margin-bottom:1rem; background:rgba(239,68,68,0.15); color:#ef4444;';
          dialogIconContainer.innerHTML = rejectIcon;
        }
        overlay.classList.remove('hiding');
        overlay.classList.add('show');
        document.body.style.overflow = 'hidden';
      }

      function closeDialog() {
        overlay.classList.add('hiding');
        setTimeout(() => {
          overlay.classList.remove('show','hiding');
          overlay.style.display = 'none';
          document.body.style.overflow = '';
          pendingAction = null;
        }, 150);
      }

      dialogCancel.addEventListener('click', closeDialog);
      dialogConfirm.addEventListener('click', () => {
        if (pendingAction === 'approve') document.getElementById('form-approve').submit();
        else if (pendingAction === 'reject') document.getElementById('form-reject').submit();
        closeDialog();
      });
      overlay.addEventListener('click', (e) => { if (e.target === overlay) closeDialog(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && overlay.classList.contains('show')) closeDialog(); });
    </script>
    <% } %>
  </body>
</html>
