<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
        document.addEventListener("basecoat:theme", (e) => {
          const mode = e.detail?.mode;
          const dark = mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark");
          document.documentElement.classList.toggle("dark", dark);
          try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
        });
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> — Facultyware</title>

    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="stylesheet" href="/assets/styles.css" />

    <script src="/assets/js/basecoat.js?v=0.3.11" defer></script>
    <script src="/assets/js/sidebar.js?v=0.3.11" defer></script>
  </head>

  <body>
    <script>
      (() => {
        document.addEventListener("DOMContentLoaded", () => {
          const sidebar = document.getElementById("sidebar");
          if (!sidebar) return;
          const updateCurrentLinks = () => {
            const currentPath = window.location.pathname.replace(/\/$/, "");
            sidebar.querySelectorAll("a").forEach((item) => {
              const href = item.getAttribute("href");
              if (!href) return;
              try {
                const url = new URL(href, window.location.origin);
                if (currentPath.startsWith(url.pathname.replace(/\/$/, ""))) {
                  item.setAttribute("aria-current", "page");
                } else {
                  item.removeAttribute("aria-current");
                }
              } catch (_) {}
            });
          };
          updateCurrentLinks();
        });
      })();
    </script>

    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
      <nav aria-label="Sidebar navigation">
        <header>
          <a href="/wakildekan/permohonan" class="btn-ghost p-2 h-12 w-full justify-start">
            <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <div class="grid flex-1 text-left text-sm leading-tight ml-2">
              <span class="truncate font-medium">Facultyware</span>
              <span class="truncate text-xs text-muted-foreground">Wakil Dekan</span>
            </div>
          </a>
        </header>

        <div class="scrollbar p-2 flex-1 overflow-y-auto">
          <div role="group" aria-labelledby="group-wakildekan">
            <h3 id="group-wakildekan" class="px-2 py-1 text-xs font-semibold text-muted-foreground uppercase tracking-wider">Permohonan Pengadaan</h3>
            <ul class="mt-1 space-y-0.5">
              <li>
                <a href="/wakildekan/permohonan" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                  Daftar Permohonan
                </a>
              </li>
              <li>
                <a href="/wakildekan/riwayat" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
                  Riwayat Keputusan
                </a>
              </li>
              <li>
                <a href="/wakildekan/api/permohonan" target="_blank" class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-sidebar-accent text-muted-foreground">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                  API JSON
                </a>
              </li>
            </ul>
          </div>
        </div>

        <footer class="p-2 border-t border-sidebar-border">
          <div class="flex items-center gap-2 rounded-md px-2 py-1.5">
            <div class="flex aspect-square size-8 items-center justify-center rounded-full bg-muted text-sm font-medium">
              <%= locals.username ? locals.username.charAt(0).toUpperCase() : 'W' %>
            </div>
            <div class="grid flex-1 text-left text-sm leading-tight">
              <span class="truncate font-medium"><%= locals.username || 'Wakil Dekan' %></span>
              <span class="truncate text-xs text-muted-foreground">Wakil Dekan</span>
            </div>
            <a href="/logout" class="btn-sm-ghost px-2" data-tooltip="Keluar" data-side="top">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </a>
          </div>
        </footer>
      </nav>
    </aside>

    <main id="content">
      <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
        <div class="flex h-14 w-full items-center gap-2 px-4">
          <button
            type="button"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
            aria-label="Toggle sidebar"
            class="btn-sm-icon-ghost mr-auto size-7 -ml-1.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2"/>
              <path d="M9 3v18"/>
            </svg>
          </button>

          <button
            type="button"
            aria-label="Toggle dark mode"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
            class="btn-icon-outline size-8"
          >
            <span class="hidden dark:block">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2m-7.07-14.07 1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2m-4.93 7.07-1.41-1.41M6.34 6.34 4.93 4.93"/></svg>
            </span>
            <span class="block dark:hidden">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            </span>
          </button>
        </div>
      </header>

      <div class="p-4 md:p-6 xl:p-8">
        <div class="max-w-screen-lg mx-auto">
          
          <div class="mb-6">
            <a href="/wakildekan/permohonan" class="btn-sm-outline inline-flex items-center gap-1.5 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              Kembali
            </a>
            <h1 class="text-2xl font-bold tracking-tight"><%= title %></h1>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Informasi Permohonan -->
            <div class="col-span-1 md:col-span-1">
              <div class="card p-5">
                <h3 class="font-semibold text-lg mb-4">Informasi</h3>
                <dl class="space-y-4 text-sm">
                  <div>
                    <dt class="text-muted-foreground mb-1">Nomor Request</dt>
                    <dd class="font-mono font-medium"><%= permohonan.request_number %></dd>
                  </div>
                  <div>
                    <dt class="text-muted-foreground mb-1">Judul</dt>
                    <dd class="font-medium"><%= permohonan.title %></dd>
                  </div>
                  <div>
                    <dt class="text-muted-foreground mb-1">Diajukan Oleh</dt>
                    <dd class="font-medium"><%= permohonan.created_by_name %></dd>
                  </div>
                  <div>
                    <dt class="text-muted-foreground mb-1">Tanggal</dt>
                    <dd class="font-medium"><%= new Date(permohonan.created_at).toLocaleDateString('id-ID') %></dd>
                  </div>
                  <div>
                    <dt class="text-muted-foreground mb-1">Status</dt>
                    <dd>
                      <%
                        let badgeCls = 'badge-outline';
                        let label = permohonan.status;
                        if (permohonan.status === 'submitted') { badgeCls = 'badge-secondary'; label = 'Diajukan'; }
                        else if (permohonan.status === 'approved') { badgeCls = 'badge-default'; label = 'Disetujui'; }
                        else if (permohonan.status === 'rejected') { badgeCls = 'badge-destructive'; label = 'Ditolak'; }
                        else if (permohonan.status === 'draft') { badgeCls = 'badge-muted'; label = 'Draft'; }
                        else if (permohonan.status === 'completed') { badgeCls = 'badge-secondary'; label = 'Selesai'; }
                      %>
                      <span class="badge <%= badgeCls %>"><%= label %></span>
                    </dd>
                  </div>
                </dl>

                <% if (permohonan.status === 'submitted') { %>
                <div class="mt-6 flex flex-col gap-2 pt-6 border-t">
                  <form action="/wakildekan/permohonan/<%= permohonan.id %>/approve" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menyetujui permohonan ini?');">
                    <button type="submit" class="btn w-full" style="background-color: #16a34a; color: white;">Setujui</button>
                  </form>
                  <form action="/wakildekan/permohonan/<%= permohonan.id %>/reject" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menolak permohonan ini?');">
                    <button type="submit" class="btn-destructive w-full">Tolak</button>
                  </form>
                </div>
                <% } %>
              </div>
            </div>

            <!-- Item List -->
            <div class="col-span-1 md:col-span-2">
              <div class="card p-0 overflow-hidden">
                <div class="p-5 border-b bg-muted/20">
                  <h3 class="font-semibold text-lg">Daftar Barang</h3>
                </div>
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b bg-muted/50">
                        <th class="px-4 py-3 text-left font-medium text-muted-foreground">No</th>
                        <th class="px-4 py-3 text-left font-medium text-muted-foreground">Nama Barang</th>
                        <th class="px-4 py-3 text-left font-medium text-muted-foreground">Spesifikasi</th>
                        <th class="px-4 py-3 text-right font-medium text-muted-foreground">Jumlah</th>
                        <th class="px-4 py-3 text-right font-medium text-muted-foreground">Estimasi Harga</th>
                        <th class="px-4 py-3 text-right font-medium text-muted-foreground">Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% let grandTotal = 0; %>
                      <% if (items && items.length > 0) { %>
                        <% items.forEach((item, i) => { 
                             const itemTotal = item.quantity * item.estimated_price;
                             grandTotal += itemTotal;
                        %>
                        <tr class="border-b last:border-0 hover:bg-muted/30 transition-colors">
                          <td class="px-4 py-3 text-muted-foreground"><%= i + 1 %></td>
                          <td class="px-4 py-3 font-medium"><%= item.name %></td>
                          <td class="px-4 py-3 text-muted-foreground"><%= item.specification || '-' %></td>
                          <td class="px-4 py-3 text-right"><%= item.quantity %></td>
                          <td class="px-4 py-3 text-right tabular-nums"><%= Number(item.estimated_price).toLocaleString('id-ID', { style: 'currency', currency: 'IDR' }) %></td>
                          <td class="px-4 py-3 text-right tabular-nums font-medium"><%= Number(itemTotal).toLocaleString('id-ID', { style: 'currency', currency: 'IDR' }) %></td>
                        </tr>
                        <% }) %>
                      <% } else { %>
                        <tr>
                          <td colspan="6" class="px-4 py-8 text-center text-muted-foreground">Tidak ada item</td>
                        </tr>
                      <% } %>
                    </tbody>
                  </table>
                </div>
                <div class="p-4 border-t bg-muted/20 flex justify-between items-center">
                  <span class="font-semibold text-muted-foreground">Total Estimasi Keseluruhan</span>
                  <span class="text-lg font-bold tabular-nums text-foreground"><%= Number(grandTotal).toLocaleString('id-ID', { style: 'currency', currency: 'IDR' }) %></span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </main>
  </body>
</html>
